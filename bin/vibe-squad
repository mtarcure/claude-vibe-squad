#!/usr/bin/env bash
set -euo pipefail

# Load ONLY the daemon token — do NOT source all secrets. Model CLIs would
# otherwise inherit DEEPSEEK/OPENAI/xAI/etc keys and one of them displays
# key contents in ANSI terminal-title codes (security leak in the tab bar).
export VIBESQUAD_DAEMON_TOKEN=$(grep '^export VIBESQUAD_DAEMON_TOKEN=' ~/.config/shell/secrets.zsh 2>/dev/null | head -1 | sed 's/^export VIBESQUAD_DAEMON_TOKEN=//' | tr -d '"')
if [[ -z "${VIBESQUAD_DAEMON_TOKEN:-}" ]]; then
    echo "error: VIBESQUAD_DAEMON_TOKEN not found in ~/.config/shell/secrets.zsh"
    exit 1
fi

REPO="/Users/user/Obsidian-Claude-Vibe-Squad"

# Ensure daemon is up
if ! curl -sf http://127.0.0.1:9876/health >/dev/null 2>&1; then
    echo "starting daemon..."
    launchctl start com.vibesquad.daemon
    for i in {1..10}; do
        if curl -sf http://127.0.0.1:9876/health >/dev/null 2>&1; then break; fi
        sleep 0.5
    done
    if ! curl -sf http://127.0.0.1:9876/health >/dev/null 2>&1; then
        echo "error: daemon failed to start within 10s"
        exit 1
    fi
fi

# Ensure Chrome is up
if ! curl -sf http://127.0.0.1:9222/json/version >/dev/null 2>&1; then
    echo "starting Chrome..."
    launchctl start com.vibesquad.chrome
fi

# Launch Ink app — explicitly clear ALL non-essential API keys so no subprocess
# ever sees them. Only VIBESQUAD_DAEMON_TOKEN remains for daemon auth.
cd "$REPO/ink-app"
exec env \
    -u DEEPSEEK_API_KEY \
    -u XAI_API_KEY \
    -u MOONSHOT_API_KEY \
    -u PERPLEXITY_API_KEY \
    -u SERPER_API_KEY \
    -u BRAVE_API_KEY \
    -u APIFY_TOKEN \
    -u ELEVENLABS_API_KEY \
    -u GOOGLE_API_KEY \
    -u GEMINI_API_KEY \
    -u OPENAI_API_KEY \
    -u ANTHROPIC_API_KEY \
    -u DIGITALOCEAN_ACCESS_TOKEN \
    -u TWITTER_BEARER_TOKEN \
    -u TWITTER_CONSUMER_KEY \
    -u TWITTER_CONSUMER_SECRET \
    -u TWITTER_ACCESS_TOKEN \
    -u TWITTER_ACCESS_TOKEN_SECRET \
    -u TWITTER_CLIENT_ID \
    -u TWITTER_CLIENT_SECRET \
    -u CHRONO_TG_TOKEN \
    -u CHRONO_TG_CHAT_ID \
    -u OBSIDIAN_REST_API_KEY \
    -u HIBP_API_KEY \
    -u SHODAN_API_KEY \
    -u CENSYS_API_ID \
    -u CENSYS_API_SECRET \
    -u HUNTER_API_KEY \
    -u ABUSEIPDB_KEY \
    -u GH_TOKEN \
    VIBESQUAD_DAEMON_TOKEN="$VIBESQUAD_DAEMON_TOKEN" \
    npm run start
