{
  "version": 1,
  "description": "Canonical current-tree publication policy. Exact public exceptions win over deny rules; deny rules win over public namespace rules; unmatched paths are unknown and fail the export gate.",
  "public_exceptions": [
    "_state/dream-config.yaml",
    "_state/.gitkeep",
    "departments/*/inbox/.gitkeep",
    "departments/*/active/.gitkeep",
    "departments/*/outbox/.gitkeep",
    "departments/*/archive/.gitkeep"
  ],
  "deny": [
    "_state/**",
    "departments/*/inbox/**",
    "departments/*/active/**",
    "departments/*/outbox/**",
    "departments/*/archive/**",
    "departments/*/_state/**",
    "**/current.md",
    "**/memory.md",
    "_archive/**",
    "projects/**",
    "docs/design/**",
    "docs/handoffs/**",
    "docs/plans/**",
    "docs/specs/**",
    "docs/lineage.md",
    "**/.env",
    "**/.env.*",
    "**/*secret*.json",
    "**/*.key",
    "**/*.pem",
    "**/*.p12",
    "**/*.pfx",
    "**/.claude/settings.local.json",
    "model-lanes/*/.gemini/settings.json",
    "model-lanes/claude/.mcp.json",
    "model-lanes/claude/.mcp.security-arsenal.staged.json",
    "model-lanes/gpt-codex/.codex/config.toml",
    "model-lanes/gpt-codex/.codex/security-arsenal.staged.toml",
    "plugins/security-mcp-stack/held-solodit.json",
    "plugins/security-mcp-stack/preactivate-security-stack.sh",
    "plugins/security-mcp-stack/snyk-preactivation-targets.json",
    "**/*.local.md",
    "**/*.log",
    "logs/**",
    "**/kg.db*",
    "**/*.db-wal",
    "**/*.db-shm",
    ".obsidian/workspace*",
    ".obsidian/cache/**",
    ".obsidian/plugins/*/data.json",
    "_state/repo-split-2026-07-16/identifier-denylist.txt"
  ],
  "public": [
    ".agents/skills/**",
    ".claude/**",
    ".claude-plugin/**",
    ".githooks/**",
    ".github/**",
    ".gitignore",
    ".python-version",
    "AGENTS.md",
    "CHANGELOG.md",
    "CLAUDE.md",
    "CONTRIBUTING.md",
    "GEMINI.md",
    "LICENSE",
    "README.md",
    "pyproject.toml",
    "requirements-dev.txt",
    "uv.lock",
    "assets/**",
    "bin/**",
    "chrono/**",
    "daemon/**",
    "departments/**",
    "docs/**",
    "examples/**",
    "launchd/**",
    "moat/**",
    "model-lanes/**",
    "plugins/**",
    "scripts/**",
    "shared/**",
    "tests/**",
    "tools/**"
  ]
}
