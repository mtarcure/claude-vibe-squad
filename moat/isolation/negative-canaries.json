{
  "content_class": "public-safe",
  "profile_version": "1.0.0",
  "abort_on_unexpected_success": true,
  "require_loopback_control_success": true,
  "probes": [
    { "id": "canary:ipv4-direct", "class": "ipv4", "destination": "192.0.2.1", "address_family": 4, "expected": "blocked" },
    { "id": "canary:ipv6-direct", "class": "ipv6", "destination": "2001:db8::1", "address_family": 6, "expected": "blocked" },
    { "id": "canary:dns-external", "class": "dns", "destination": "example.com", "expected": "resolution-fails" },
    { "id": "canary:http-proxy", "class": "proxy_environment", "destination": "https://example.com/", "environment_variables": ["HTTP_PROXY", "HTTPS_PROXY", "ALL_PROXY", "NO_PROXY"], "expected": "blocked-or-unset" },
    { "id": "canary:host-gateway", "class": "host_gateway", "destination": "host.docker.internal", "expected": "unreachable" },
    { "id": "canary:tls-external", "class": "tcp_tls", "destination": "example.com:443", "expected": "connection-fails" },
    { "id": "control:loopback-oracle", "class": "loopback_control", "destination": "http://127.0.0.1:8080/health", "expected": "reachable" }
  ]
}
